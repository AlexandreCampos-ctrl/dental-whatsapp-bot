# Configurações do Bot — DentalPro Secretária Virtual

# Nome da clínica (aparece nas mensagens)
CLINIC_NAME="DentalPro"

# Nome da secretária virtual
BOT_NAME="Dani"

# Número do proprietário/admin (com código do país, sem +)
# Exemplo: 5511999990000
OWNER_NUMBER="5511999990000"

# Horário de funcionamento
CLINIC_OPEN="08:00"
CLINIC_CLOSE="18:00"

# Tempo do lembrete automático (em horas antes da consulta)
REMINDER_HOURS=24

# Modo DEBUG (true = mostra logs detalhados)
DEBUG=false
